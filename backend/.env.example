MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/
MONGODB_DB_NAME=DEV-ChurchNavigator
JWT_SECRET_KEY=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=10080
FRONTEND_URL=http://localhost:3000

# OAuth Configuration - MANUAL ACTION REQUIRED
# Google: Get credentials from https://console.cloud.google.com/apis/credentials
# Facebook: Get credentials from https://developers.facebook.com/apps/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
OAUTH_REDIRECT_URI=https://api.churchnavigator.com