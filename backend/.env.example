MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/
MONGODB_DB_NAME=DEV-ChurchNavigator
JWT_SECRET_KEY=your-secret-key-here-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=10080
FRONTEND_URL=http://localhost:3000

# OAuth2 Configuration - MANUAL ACTION REQUIRED
# Google: Create OAuth2 credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {BACKEND_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Facebook: Create app at https://developers.facebook.com/apps
# Valid OAuth Redirect URI: {BACKEND_URL}/api/auth/facebook/callback
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret