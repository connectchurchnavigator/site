MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/
MONGODB_DB_NAME=DEV-ChurchNavigator
JWT_SECRET_KEY=your-secret-key-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=10080
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/cuizrvzly

# OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# MANUAL ACTION REQUIRED:
# 1. Google: Create OAuth app at https://console.cloud.google.com/apis/credentials
#    - Set authorized redirect URI: {BACKEND_URL}/api/auth/google/callback
# 2. Facebook: Create app at https://developers.facebook.com/apps/
#    - Add Facebook Login product
#    - Set Valid OAuth Redirect URI: {BACKEND_URL}/api/auth/facebook/callback